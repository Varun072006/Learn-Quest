# LearnQuest Environment Configuration
# Copy this file to .env and modify as needed

# Database Configuration
# For local development (default)
MONGO_URL=mongodb://db:27017
MONGO_DB=learnquest

# For shared database (uncomment and modify)
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/
# MONGO_DB=learnquest

# Security
JWT_SECRET_KEY=your-secret-key-change-in-production

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/login

# ChromaDB Configuration
CHROMA_HOST=chroma
CHROMA_PORT=8000

# Ollama Configuration (for AI features)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# API Configuration
API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# Email Configuration (for certificate delivery)
# For Gmail: Use App Password (not regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=noreply@learnquest.com
SMTP_FROM_NAME=LearnQuest Certifications

# Leave empty for development (will print to console instead of sending)
